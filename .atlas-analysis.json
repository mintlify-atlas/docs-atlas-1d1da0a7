  "keyFeatures": [
    "Modular plugin architecture with 10+ built-in modules",
    "Support for REST, GraphQL, and WebSocket APIs",
    "Built-in authentication with multiple sign-in methods",
    "Database module with MongoDB and PostgreSQL support",
    "Auto-generated API documentation (Swagger/GraphQL)",
    "Storage integration with multiple cloud providers",
    "Email, SMS, and push notification capabilities",
    "Real-time chat functionality",
    "gRPC-based microservices communication",
    "Admin dashboard for configuration and management"
  ],
  "publicApiSurface": [
    "@conduitplatform/grpc-sdk - Core SDK for building Conduit modules",
    "@conduitplatform/module-tools - Utilities for module development",
    "@conduitplatform/hermes - HTTP/WebSocket routing library",
    "Authentication Module - User authentication with multiple providers",
    "Database Module - Schema management and CRUD operations",
    "Router Module - REST/GraphQL/WebSocket endpoint management",
    "Storage Module - File upload and cloud storage integration",
    "Email Module - Email sending with multiple providers",
    "SMS Module - Text messaging and 2FA support",
    "Push Notifications Module - Mobile push notifications",
    "Chat Module - Real-time chat functionality",
    "Forms Module - Form submission handling"
  ]
